# ~/.zshrc

# ─── Zinit 初始化 ────────────────────────────────────────────────
if [[ ! -f $HOME/.local/share/zinit/zinit.git/zinit.zsh ]]; then
    print -P "%F{33}Installing Zinit...%f"
    command mkdir -p "$HOME/.local/share/zinit" && command chmod g-rwX "$HOME/.local/share/zinit"
    command git clone https://github.com/zdharma-continuum/zinit "$HOME/.local/share/zinit/zinit.git"
fi

source "$HOME/.local/share/zinit/zinit.git/zinit.zsh"
autoload -Uz _zinit
(( ${+_comps} )) && _comps[zinit]=_zinit

# Zinit annexes
zinit light-mode for \
    zdharma-continuum/zinit-annex-as-monitor \
    zdharma-continuum/zinit-annex-bin-gem-node \
    zdharma-continuum/zinit-annex-patch-dl \
    zdharma-continuum/zinit-annex-rust

# zbbr setting for highlight
ABBR_SET_LINE_CURSOR=1
ABBR_DEFAULT_BINDINGS=1

autoload -Uz compinit && compinit

# ─── 插件 ────────────────────────────────────────────────────────
zinit light zsh-users/zsh-autosuggestions
zinit light zdharma-continuum/fast-syntax-highlighting
zinit light Aloxaf/fzf-tab
zinit light olets/zsh-abbr
zinit light zsh-users/zsh-history-substring-search

# fish-like completion experience
zstyle ':completion:*' menu select
zstyle ':completion:*' list-colors ${(s.:.)LS_COLORS}
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Z}'
zstyle ':fzf-tab:complete:cd:*' fzf-preview 'exa --color=always $realpath'
zstyle ':fzf-tab:*' switch-group ',' '.'  # 用 , . 切换补全组


# ─── Prompt ──────────────────────────────────────────────────────
zinit ice depth=1
zinit light romkatv/powerlevel10k
# 如果你有 p10k 配置文件
[[ -f ~/.p10k.zsh ]] && source ~/.p10k.zsh

# ─── 环境变量 ────────────────────────────────────────────────────
export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8
export LANGUAGE=en_US.UTF-8

export GPG_TTY=$TTY
export EDITOR="nvim"

export SYS_LOCAL_BIN="/usr/local/bin"
export LOCAL_BIN="$HOME/.local/bin"
export GOROOT="/usr/lib/go"
export GOPATH="$HOME/go"
export GOBIN="$HOME/go/bin"
export HS_BIN="$HOME/.cabal/bin"
export NPM_BIN="$HOME/.npm-global/bin"
export KT_BIN="$HOME/.kotlin/bin"
export RS_BIN="$HOME/.cargo/bin"
export JAVA_HOME="/usr/lib/jvm/default"

export PATH=$SYS_LOCAL_BIN:$LOCAL_BIN:$GOBIN:$HS_BIN:$NPM_BIN:$RS_BIN:$JAVA_HOME/bin:$PATH
path=(~/bin $path)

export HTTP_PROXY="http://127.0.0.1:7890"
export HTTPS_PROXY="http://127.0.0.1:7890"
export ALL_PROXY="http://127.0.0.1:7890"

export RIPGREP_CONFIG_PATH=$HOME/.ripgreprc

# ─── autosuggestions 配置 ────────────────────────────────────────
HISTFILE=~/.zsh_history
HISTSIZE=65535
SAVEHIST=65535
setopt share_history          # 多个 session 共享 history
setopt hist_ignore_dups       # 忽略连续重复命令
setopt hist_ignore_all_dups   # 忽略所有重复命令
setopt hist_ignore_space      # 忽略以空格开头的命令
setopt hist_verify            # 展开历史命令前先确认
setopt inc_append_history     # 实时写入 history 文件
ZSH_AUTOSUGGEST_STRATEGY=(history completion)
bindkey '→' autosuggest-accept   # 右箭头接受补全

# ─── 按键绑定 ────────────────────────────────────────────────────
bindkey '^[[A' history-substring-search-up   # ↑ 按子串搜索历史
bindkey '^[[B' history-substring-search-down # ↓ 按子串搜索历史

bindkey '^H'   backward-kill-word    # Ctrl+Backspace
bindkey '^[^H' backward-kill-word    # Ctrl+Alt+Backspace
bindkey '^_'   undo                  # Ctrl+/
bindkey '^[/'  redo                  # Alt+/
bindkey '\t'   menu-complete         # Tab iter completion
bindkey '\e[Z' reverse-menu-complete # Shift+Tab reverse iter completion

# ─── Shell 选项 ──────────────────────────────────────────────────
setopt glob_dots
setopt no_auto_menu
autoload -Uz zmv

# ─── 函数 ────────────────────────────────────────────────────────
mkcd() {
    mkdir -p "$@" && cd "$_"
}

# 替代 OMZ extract，支持所有常见格式
extract() {
    local file="$1"
    case "$file" in
        *.tar.bz2)  tar xjf "$file"    ;;
        *.tar.gz)   tar xzf "$file"    ;;
        *.tar.xz)   tar xJf "$file"    ;;
        *.tar.zst)  tar --zstd -xf "$file" ;;
        *.tar)      tar xf  "$file"    ;;
        *.bz2)      bunzip2 "$file"    ;;
        *.gz)       gunzip  "$file"    ;;
        *.zip)      unzip   "$file"    ;;
        *.7z)       7z x    "$file"    ;;
        *.rar)      unrar x "$file"    ;;
        *.zst)      zstd -d "$file"    ;;
        *)          echo "不支持的格式: $file" ;;
    esac
}

# 替代 OMZ sudo plugin
_sudo-command-line() {
    [[ -z $BUFFER ]] && zle up-history
    if [[ $BUFFER == sudo\ * ]]; then
        LBUFFER="${LBUFFER#sudo }"
    else
        LBUFFER="sudo $LBUFFER"
    fi
}
zle -N _sudo-command-line
bindkey '\e\e' _sudo-command-line  # 按两下 Esc

# 超过 10 秒的命令完成后发送通知
__notify_threshold=10
__cmd_start=0
__last_cmd=""

# 黑名单，这些命令不发通知
__notify_blacklist=(
    nvim vim vi nano
    htop btop top
    lazygit tig
    ranger yazi
    fzf less more bat
    man ssh
)

preexec() {
    __cmd_start=$SECONDS
    # 只取命令名，去掉参数
    __last_cmd="$1"
    __last_cmd_name="${1%% *}"
}

__notify() {
    local title="$1"
    local body="$2"
    notify-send "$title" "$body"
}

__in_blacklist() {
    local cmd="$1"
    for b in "${__notify_blacklist[@]}"; do
        [[ "$cmd" == "$b" ]] && return 0
    done
    return 1
}

precmd() {
    local exit_code=$?
    local elapsed=$(( SECONDS - __cmd_start ))
    if (( __cmd_start > 0 && elapsed >= __notify_threshold )); then
        if ! __in_blacklist "$__last_cmd_name"; then
            if (( exit_code == 0 )); then
                __notify "✅ 任务完成" "${__last_cmd} (${elapsed}s)"
            else
                __notify "❌ 任务失败: ${__last_cmd_name}" "exit code: ${exit_code} (${elapsed}s)"
            fi
        fi
    fi
    __cmd_start=0
}

# ─── Tmux 自动启动 ───────────────────────────────────────────────
if [[ -o interactive ]] \
    && [[ -z "$TMUX" ]] \
    && [[ "$TERM" != "xterm-kitty" ]] \
    && [[ "$TERM" != "alacritty" ]] \
    && [[ -z "$NVIM" ]] \
    && [[ -z "$NVIM_LISTEN_ADDRESS" ]] \
    && [[ "$TERM_PROGRAM" != "vscode" ]] \
    && [[ "$TERMINAL_EMULATOR" != "JetBrains-JediTerm" ]] \
    && [[ "$VSCODE_INJECTION" != "1" ]] \
    && [[ -z "$VSCODE_PID" ]] \
    && [[ -z "$VSCODE_IPC_HOOK" ]]; then
    exec tmux -u new -A -D -t main
fi


